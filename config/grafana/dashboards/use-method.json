  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "cores"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum by (service, replica) (rate(process_cpu_seconds_total{service=~\"frontend|backend\"}[1m])) or sum by (service, replica) ((rate(sys_cpu_user_ns{service=\"database\"}[1m]) + rate(sys_cpu_sys_ns{service=\"database\"}[1m])) / 1e9)", "legendFormat": "{{service}} {{replica}}", "refId": "A"}],
      "title": "Utilization: CPU Cores By Service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "targets": [{"expr": "sum by (service, replica) (process_resident_memory_bytes{service=~\"frontend|backend\"}) or sum by (service, replica) (sys_rss{service=\"database\"})", "legendFormat": "{{service}} {{replica}}", "refId": "A"}],
      "title": "Utilization: Memory By Service",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "percent"}, "overrides": []},
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 8},
      "id": 3,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(demo_fault_state{fault=\"error_rate\"}) by (replica)", "legendFormat": "{{replica}}", "refId": "A"}],
      "title": "Errors: Injected Backend Error Rate",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "decmbytes"}, "overrides": []},
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 8},
      "id": 4,
      "options": {"colorMode": "value", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "textMode": "auto"},
      "targets": [{"expr": "max(demo_fault_state{fault=\"memory_mb\"}) by (replica)", "legendFormat": "{{replica}}", "refId": "A"}],
      "title": "Saturation: Retained Fault Memory",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 6, "w": 8, "x": 16, "y": 8},
      "id": 5,
      "targets": [
        {"expr": "sum by (service, replica) (rate(demo_http_request_bytes_total{service=~\"frontend|backend\"}[1m])) or sum by (service, replica) (rate(sys_host_net_recv_bytes{service=\"database\"}[1m]))", "legendFormat": "rx {{service}} {{replica}}", "refId": "A"},
        {"expr": "sum by (service, replica) (rate(demo_http_response_bytes_total{service=~\"frontend|backend\"}[1m])) or sum by (service, replica) (rate(sys_host_net_send_bytes{service=\"database\"}[1m]))", "legendFormat": "tx {{service}} {{replica}}", "refId": "B"}
      ],
      "title": "Utilization: Network IO",
      "type": "timeseries"
    }
