    {"asDropdown": false, "icon": "external link", "includeVars": false, "keepTime": true, "tags": [], "targetBlank": true, "title": "Trace Checkout", "tooltip": "Open Tempo checkout traces", "type": "link", "url": "/explore?left={\"datasource\":\"tempo\",\"queries\":[{\"query\":\"{ name = \\\"GET /shop\\\" }\",\"queryType\":\"traceql\",\"refId\":\"A\"}],\"range\":{\"from\":\"now-30m\",\"to\":\"now\"}}"}
  ],
  "panels": [
    {
      "datasource": {"type": "__expr__", "uid": "__expr__"},
      "gridPos": {"h": 5, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "options": {"content": "Real-life use case: a user clicks checkout in the frontend. The frontend calls backend /api/products, then backend /api/checkout writes an order to CockroachDB. Start with journey latency and error ratio, then inspect backend logs with trace_id, open the trace in Tempo, and use Pyroscope if CPU is abnormal.", "mode": "markdown"},
      "title": "Checkout Journey: Frontend To Backend To Database",
      "type": "text"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 5},
      "id": 2,
      "targets": [
        {"expr": "sum(rate(demo_http_requests_total{service=\"frontend\", route=\"/shop\"}[1m]))", "legendFormat": "frontend /shop", "refId": "A"},
        {"expr": "sum(rate(demo_http_requests_total{service=\"backend\", route=~\"/api/products|/api/checkout\"}[1m])) by (route)", "legendFormat": "backend {{route}}", "refId": "B"}
      ],
      "title": "Journey Traffic",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 5},
      "id": 3,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum(rate(demo_http_request_duration_seconds_bucket{service=\"frontend\", route=\"/shop\"}[5m])) by (le))", "legendFormat": "frontend /shop p95", "refId": "A"},
        {"expr": "histogram_quantile(0.95, sum(rate(demo_http_request_duration_seconds_bucket{service=\"backend\", route=~\"/api/products|/api/checkout\"}[5m])) by (le, route))", "legendFormat": "backend {{route}} p95", "refId": "B"}
      ],
      "title": "Journey Latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 5},
      "id": 4,
      "targets": [
        {"expr": "sum(rate(demo_http_requests_total{service=\"frontend\", route=\"/shop\", status=~\"5..\"}[1m]))", "legendFormat": "frontend /shop 5xx", "refId": "A"},
        {"expr": "sum(rate(demo_http_requests_total{service=\"backend\", route=~\"/api/products|/api/checkout\", status=~\"5..\"}[1m])) by (route)", "legendFormat": "backend {{route}} 5xx", "refId": "B"}
      ],
      "title": "Journey Errors",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 0, "y": 13},
      "id": 5,
      "targets": [{"expr": "sum(rate(sql_conns{service=\"database\"}[1m])) by (replica)", "legendFormat": "{{replica}}", "refId": "A"}],
      "title": "Database Connection Churn",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "Bps"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 8, "y": 13},
      "id": 6,
      "targets": [
        {"expr": "sum(rate(demo_http_response_bytes_total{service=~\"frontend|backend\", route=~\"/shop|/api/products|/api/checkout\"}[1m])) by (service, route)", "legendFormat": "tx {{service}} {{route}}", "refId": "A"},
        {"expr": "sum(rate(demo_http_request_bytes_total{service=~\"frontend|backend\", route=~\"/shop|/api/products|/api/checkout\"}[1m])) by (service, route)", "legendFormat": "rx {{service}} {{route}}", "refId": "B"}
      ],
      "title": "Journey HTTP Bytes",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "fieldConfig": {"defaults": {"unit": "cores"}, "overrides": []},
      "gridPos": {"h": 7, "w": 8, "x": 16, "y": 13},
      "id": 7,
      "targets": [
        {"expr": "sum(rate(process_cpu_seconds_total{service=~\"frontend|backend\"}[1m])) by (service, replica)", "legendFormat": "{{service}} {{replica}}", "refId": "A"},
        {"expr": "sum((rate(sys_cpu_user_ns{service=\"database\"}[1m]) + rate(sys_cpu_sys_ns{service=\"database\"}[1m])) / 1e9) by (service, replica)", "legendFormat": "{{service}} {{replica}}", "refId": "B"}
      ],
      "title": "CPU While Checkout Runs",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 20},
      "id": 8,
      "options": {"dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": false, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true},
      "targets": [{"expr": "{service=~\"frontend|backend\"} | logfmt | route=~\"/shop|/api/products|/api/checkout\"", "refId": "A"}],
      "title": "Journey Logs With Trace IDs",
      "type": "logs"
    },
    {
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 20},
      "id": 9,
      "options": {"dedupStrategy": "none", "enableLogDetails": true, "prettifyLogMessage": true, "showCommonLabels": false, "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true},
      "targets": [{"expr": "{service=\"backend\"} | json | event=~\"fault.*\"", "refId": "A"}],
      "title": "Fault Events Affecting Checkout",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
