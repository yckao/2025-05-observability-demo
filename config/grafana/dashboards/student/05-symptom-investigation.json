      "targets": [{"expr": "histogram_quantile(0.95, sum(rate(demo_http_request_duration_seconds_bucket{service=\"backend\"}[5m])) by (le, replica, route))", "legendFormat": "{{replica}} {{route}}", "refId": "A"}],
