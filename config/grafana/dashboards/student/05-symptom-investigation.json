      "id": 5,
      "targets": [{"expr": "100 * sum by (replica) (label_replace(container_memory_working_set_bytes{id=~\".*obs-demo-(frontend-[0-9]|backend-[0-9]|crdb-[0-9])[.]slice/docker-.*\"}, \"replica\", \"$1\", \"id\", \".*obs-demo-(frontend-[0-9]|backend-[0-9]|crdb-[0-9])[.]slice/docker-.*\")) / clamp_min(sum by (replica) (label_replace(container_spec_memory_limit_bytes{id=~\".*obs-demo-(frontend-[0-9]|backend-[0-9]|crdb-[0-9])[.]slice/docker-.*\"}, \"replica\", \"$1\", \"id\", \".*obs-demo-(frontend-[0-9]|backend-[0-9]|crdb-[0-9])[.]slice/docker-.*\")), 1)", "legendFormat": "{{replica}}", "refId": "A"}],
