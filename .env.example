# Docker daemon root directory. The Makefile auto-detects this for `make up`.
# Keep this default for Docker Desktop / Linux rootful Docker.
# Rootless Docker, Lima, or Colima may use a different path.
DOCKER_ROOT_DIR=/var/lib/docker

# Public URL used by the student UI when linking to Grafana.
# For Cloudflare Tunnel workshops, set this to the public Grafana hostname.
PUBLIC_GRAFANA_URL=http://localhost:3000
